extends ../layouts/main-layout.pug
include ./add-to-cart.pug

block styles
  link(rel="stylesheet", href="/css/product-detail.css")

block content
  .product-container
    .product-card

      // LEFT - IMAGE
      .image-section
        img.product-image(src=product.imageURL, alt=product.name)

      // RIGHT - DETAILS
      .details-section
        h1.product-title= product.name

        .price ₹#{product.price}

        p.description= product.description

        .actions
          +addToCart(product)
          button.btn-card Buy Now

  // OPTIONAL: EXTRA INFO SECTION
  .extra-section
    h2 Product Details
    ul
      li High quality product
      li 7 days replacement available
      li Cash on delivery supported